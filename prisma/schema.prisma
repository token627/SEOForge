// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

model Project {
  id          String   @id @default(cuid())
  name        String
  domain      String
  createdAt   DateTime @default(now())
}

model SeoReport {
  id          String   @id @default(cuid())
  projectId   String
  score       Int
  issues      String   // Using String since SQLite json support is somewhat limited in raw prisma strings
  createdAt   DateTime @default(now())
}
